<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Acceso LabSystem | JWT Mode</title>
    <style>
        body { 
            background: #1e293b; 
            color: white; 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            height: 100vh; 
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
        }
        .login-card { 
            background: white; 
            padding: 40px; 
            border-radius: 12px; 
            color: #334155; 
            box-shadow: 0 10px 25px rgba(0,0,0,0.5); 
            width: 100%;
            max-width: 350px;
        }
        h2 { text-align: center; margin-bottom: 25px; color: #1e293b; }
        label { font-size: 0.9rem; font-weight: bold; color: #64748b; }
        input { 
            display: block; 
            width: 100%; 
            margin: 8px 0 20px 0; 
            padding: 12px; 
            border: 1px solid #cbd5e1; 
            border-radius: 6px; 
            box-sizing: border-box; 
            font-size: 1rem;
        }
        input:focus { outline: 2px solid #2563eb; border-color: transparent; }
        button { 
            width: 100%; 
            padding: 12px; 
            background: #2563eb; 
            color: white; 
            border: none; 
            border-radius: 6px; 
            font-size: 1rem; 
            font-weight: bold;
            cursor: pointer; 
            transition: background 0.3s;
        }
        button:hover { background: #1d4ed8; }
        .error-msg {
            color: #dc2626;
            background: #fef2f2;
            padding: 10px;
            border-radius: 6px;
            margin-bottom: 20px;
            font-size: 0.85rem;
            display: none;
            text-align: center;
            border: 1px solid #fecaca;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <h2>🔬 Administración</h2>
        
        <div id="error-container" class="error-msg"></div>

        <form id="login-form" autocomplete="off">
            
            <label for="username">Usuario</label>
            <input type="text" id="username" name="username" placeholder="Escribe tu usuario" required>

            <label for="password">Contraseña</label>
            <input type="password" id="password" name="password" placeholder="••••••••" required>

            <button type="submit" id="btn-entrar">Entrar al Sistema</button>
            
        </form>
    </div>

    <script>
        const loginForm = document.getElementById('login-form');
        const errorContainer = document.getElementById('error-container');
        const btnEntrar = document.getElementById('btn-entrar');

        loginForm.onsubmit = async (e) => {
            e.preventDefault(); // Evita que la página se recargue
            
            // Bloquear botón y limpiar errores
            btnEntrar.disabled = true;
            btnEntrar.innerText = "Verificando...";
            errorContainer.style.display = 'none';

            const username = document.getElementById('username').value;
            const password = document.getElementById('password').value;

            try {
                const response = await fetch('/auth', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ username, password })
                });

                const data = await response.json();

                if (data.success) {
                    // --- PUNTO CLAVE: GUARDAR DATOS EN EL NAVEGADOR ---
                    localStorage.setItem('token', data.token);
                    localStorage.setItem('user', JSON.stringify(data.user));

                    // Redireccionar al index
                    window.location.href = '/';
                } else {
                    // Mostrar error si las credenciales fallan
                    errorContainer.innerText = data.error || "Error de acceso";
                    errorContainer.style.display = 'block';
                    btnEntrar.disabled = false;
                    btnEntrar.innerText = "Entrar al Sistema";
                }
            } catch (err) {
                console.error("Error en la petición:", err);
                errorContainer.innerText = "Error de conexión con el servidor";
                errorContainer.style.display = 'block';
                btnEntrar.disabled = false;
                btnEntrar.innerText = "Entrar al Sistema";
            }
        };

        // Si ya tiene un token válido, mandarlo directo al index
        window.onload = () => {
            if (localStorage.getItem('token')) {
                window.location.href = '/';
            }
        };
    </script>
</body>
</html>